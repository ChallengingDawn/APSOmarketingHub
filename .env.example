# ── Authentication (Phase 1 — password-based) ─────────────────────────
# 32+ char random string — used to sign session JWTs.
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-32-plus-char-random-string

# Master password shared with the team for Phase 1 access.
# Use a strong, unique password (min 12 characters, mixed case + numbers + symbols).
AUTH_MASTER_PASSWORD=replace-me-with-a-strong-password

# (Optional) Extra email domains allowed to sign in, comma-separated.
# The default allow-list is: angst-pfister.com, apsoparts.com
# Example: AUTH_EXTRA_ALLOWED_DOMAINS=gmail.com,proton.me
# AUTH_EXTRA_ALLOWED_DOMAINS=

# ── Phase 1 LLM providers ──────────────────────────────────────────────
# Claude (Anthropic) — used for long-form content + suggestions.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Gemini (Google) — alternative generator (A/B quality comparison).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxx

# (Optional) Pin a specific Gemini image-generation model.
# Default cascade: gemini-3-pro-image-preview (Nano Banana Pro)
#   -> gemini-2.5-pro-image
#   -> gemini-2.5-flash-image
# Set this to force one specific model (useful to confirm which
# one your API key / project billing has access to).
# GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# ── Legacy / future ────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your-secret-here

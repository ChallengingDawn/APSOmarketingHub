# ── Authentication (magic link, Phase 1) ──────────────────────────────
# 32+ char random string — used to sign JWTs for both magic links and sessions.
# Generate with: openssl rand -base64 48
AUTH_SECRET=replace-me-with-32-plus-char-random-string

# Resend API key — sends the magic link email.
# Get one at https://resend.com/api-keys
# If unset, magic links are logged to the server console instead (dev only).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address for magic link emails. Must be a domain verified in your Resend account.
# The local-part (noreply@, hello@, etc.) can be anything — no mailbox required.
# IMPORTANT: do NOT wrap the value in quotes on Railway.
# Example (working): APSOparts Marketing Hub <noreply@challengingdawn.pt>
AUTH_EMAIL_FROM=APSOparts Marketing Hub <noreply@your-resend-verified-domain.com>

# Public URL of the app — used to build magic link URLs in emails.
# REQUIRED on Railway (where the internal origin is localhost:8080).
# Example: https://apsomarketinghub-production.up.railway.app
APP_URL=https://your-railway-domain.up.railway.app

# Dev-mode bypass: when true, the sign-in API returns the magic link in the response
# so you can click it directly without waiting for email delivery. Use this when
# corporate mail filters silently drop emails from new domains.
# SET TO FALSE (or remove) ONCE THE TEAM CAN RECEIVE EMAILS NORMALLY.
AUTH_DEV_MODE=false

# ── Legacy / future ────────────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com/webhook
N8N_WEBHOOK_SECRET=your-secret-here
